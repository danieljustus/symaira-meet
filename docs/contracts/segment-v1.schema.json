{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://symaira.dev/contracts/symmeet/segment-v1.schema.json",
  "title": "SymMeet segment v1",
  "type": "object",
  "required": ["schema_version", "segment_id", "track_id", "speaker_id", "start_ms", "end_ms", "engine_text", "revision"],
  "properties": {
    "schema_version": { "const": 1 },
    "segment_id": { "type": "string", "format": "uuid" },
    "track_id": { "type": "string", "format": "uuid" },
    "speaker_id": { "type": "string", "pattern": "^speaker_.+" },
    "start_ms": { "type": "integer", "minimum": 0 },
    "end_ms": { "type": "integer", "minimum": 1 },
    "engine_text": { "type": "string" },
    "edited_text": { "type": "string" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "revision": { "enum": ["engine", "user_corrected"] }
  },
  "additionalProperties": true
}
